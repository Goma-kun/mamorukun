{
  "manifest_version": 3,
  "name": "まもるくん POC v2",
  "version": "0.0.2",
  "description": "content script 経由で Speech API を動かす POC",
  "permissions": ["sidePanel", "activeTab", "scripting", "tabs"],
  "action": {
    "default_title": "まもるくん POC"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
